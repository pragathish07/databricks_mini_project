{
  "datasets": [
    {
      "name": "edd5bddc",
      "displayName": "KPI 1: Monthly Consolidated Revenue",
      "queryLines": [
        "SELECT SUM(total_revenue) AS total_revenue\n",
        "FROM mini_project.gold.kpi_monthly_revenue;"
      ],
      "catalog": "mini_project",
      "schema": "gold"
    },
    {
      "name": "608469a9",
      "displayName": "Monthly Revenue Performance Overview Dataset",
      "queryLines": [
        "SELECT * FROM mini_project.gold.kpi_monthly_revenue;"
      ]
    },
    {
      "name": "aceeaeb1",
      "displayName": "revenue trend",
      "queryLines": [
        "SELECT \r\n",
        "  year,\r\n",
        "  month,\r\n",
        "  SUM(total_revenue) AS revenue\r\n",
        "FROM mini_project.gold.kpi_monthly_revenue\r\n",
        "GROUP BY year, month\r\n",
        "ORDER BY year, month;"
      ]
    },
    {
      "name": "f19db785",
      "displayName": "expense",
      "queryLines": [
        "SELECT\r\n",
        "  year,\r\n",
        "  month,\r\n",
        "  department_name AS expense_dept,\r\n",
        "  SUM(total_operating_expenses) AS expense_amount\r\n",
        "FROM mini_project.gold.kpi_operating_expenses\r\n",
        "GROUP BY year, month, expense_dept;"
      ]
    },
    {
      "name": "abb51c1a",
      "displayName": "payroll vs revenue",
      "queryLines": [
        "SELECT\r\n",
        "  year,\r\n",
        "  month,\r\n",
        "  SUM(payroll_total_compensation) AS payroll,\r\n",
        "  SUM(gl_revenue) AS revenue\r\n",
        "FROM mini_project.gold.datacube_kpi\r\n",
        "GROUP BY year, month;"
      ]
    },
    {
      "name": "f1287d6c",
      "displayName": "MoM growth",
      "queryLines": [
        "SELECT\r\n",
        "  year,\r\n",
        "  month,\r\n",
        "  SUM(gl_revenue) AS revenue,\r\n",
        "  LAG(SUM(gl_revenue)) OVER (ORDER BY year, month) AS prev_revenue\r\n",
        "FROM mini_project.gold.datacube_kpi\r\n",
        "GROUP BY year, month;"
      ]
    }
  ],
